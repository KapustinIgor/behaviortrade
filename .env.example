# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bt:bt_secret@localhost:5432/behaviortrade
REDIS_URL=redis://localhost:6379/0
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=bt_neo4j_secret

# ── App ───────────────────────────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-secrets-generate
DEBUG=true
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ── Market Data APIs ──────────────────────────────────────────────────────────
COINGECKO_API_KEY=                    # Optional – free tier works without key
BINANCE_API_KEY=
BINANCE_SECRET=
COINBASE_API_KEY=
COINBASE_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=
COINMARKETCAP_API_KEY=
MESSARI_API_KEY=
KAIKO_API_KEY=

# ── On-chain / Behavioral ─────────────────────────────────────────────────────
GLASSNODE_API_KEY=
CRYPTOQUANT_API_KEY=
ETHERSCAN_API_KEY=
NANSEN_API_KEY=
DEBANK_API_KEY=

# ── Social ────────────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=BehaviorTrade/0.1 by /u/your_reddit_username
TWITTER_BEARER_TOKEN=
LUNARCRUSH_API_KEY=
SANTIMENT_API_KEY=

# ── News ──────────────────────────────────────────────────────────────────────
CRYPTOPANIC_API_KEY=                  # Free tier: https://cryptopanic.com/developers/api/
NEWSAPI_KEY=                          # Free tier: https://newsapi.org/

# ── Macro ─────────────────────────────────────────────────────────────────────
FRED_API_KEY=                         # Free: https://fred.stlouisfed.org/docs/api/api_key.html

# ── GNN / ML ──────────────────────────────────────────────────────────────────
MODEL_PATH=./models/gnn_checkpoint.pt
GNN_RETRAIN_HOUR=2                    # Hour (UTC) for nightly full retrain

# ── AI Copilot ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=                       # Required for BT Copilot chat feature
